---
interface Props {
  onHome?: boolean;
}

const { onHome = true } = Astro.props;

const withHomePrefix = (anchor: string) => (onHome ? anchor : `/${anchor}`);

const navItems = [
  { href: withHomePrefix('#intro'), label: 'Save the Date' },
  { href: withHomePrefix('#welcome'), label: 'Welcome' },
  { href: withHomePrefix('#location'), label: 'Location & Time' },
  { href: withHomePrefix('#dress-code'), label: 'Dress Code' },
  { href: withHomePrefix('#food'), label: 'Food' },
];
---

<header class="site-header">
  <a class="brand" href={onHome ? '#intro' : '/'} aria-label="Greg and Lucy wedding home">G + L</a>
  <nav class="primary-nav" aria-label="Primary navigation">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
  <a class="nav-cta" href="/rsvp">RSVP</a>
</header>
